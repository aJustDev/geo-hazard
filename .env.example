# Copia a .env.local (gitignored) y ajusta. ENVIRONMENT selecciona el fichero
# .env.<ENVIRONMENT> que carga pydantic-settings.
ENVIRONMENT=local

DB_HOST=localhost
DB_PORT=5433
DB_USER=geohazard
DB_PASSWORD=geohazard
DB_NAME=geohazard_dev

# Directorio de exports GeoParquet y datos de referencia.
DATA_DIR=./data

# Drivers de fuentes: fake (sin red) o http (real).
EFFIS_DRIVER=fake
IGN_DRIVER=fake
AEMET_DRIVER=fake
# Obligatoria solo con AEMET_DRIVER=http. Nunca se commitea.
AEMET_API_KEY=

# Defensas de disponibilidad (ADR-0017). Todos con defaults sanos.
# Rate limiting por IP: desactivable, cuota global y cuota de endpoints caros.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=120/minute
RATE_LIMIT_EXPENSIVE=20/minute
# Techo de statement_timeout (ms) del engine de la API; el compose fija ademas
# uno global mas holgado (30s) y las migraciones se eximen.
DB_STATEMENT_TIMEOUT_MS=10000
# Concurrencia maxima del plano analitico DuckDB y espera por slot antes de 503.
ANALYTICS_MAX_CONCURRENCY=4
ANALYTICS_ACQUIRE_TIMEOUT_SECONDS=0.5
# Tope de cuerpo de respuesta de upstreams (bytes) leido por streaming. 50 MB.
HTTP_MAX_RESPONSE_BYTES=52428800
