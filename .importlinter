[importlinter]
root_packages =
    app

# ---------------------------------------------------------------------------
# La infraestructura generica de app.core no debe conocer las capas de arriba
# ni el dominio. Las unicas aristas core -> hazards permitidas son el wiring:
# db_registry (composition root que puebla Base.metadata y el dispatcher) y
# los job handlers por fuente (orquestan la ingesta). Cuando nazca
# app.analytics (fase DuckDB) se anadira su contrato y el de la frontera
# hazards <-/-> analytics.
# ---------------------------------------------------------------------------
[importlinter:contract:core-sin-dependencias-hacia-arriba]
name = app.core no importa api, deps ni main
type = forbidden
source_modules =
    app.core
forbidden_modules =
    app.api
    app.deps
    app.main

[importlinter:contract:core-agnostico-del-dominio]
name = app.core no importa app.hazards ni app.analytics (salvo wiring)
type = forbidden
allow_indirect_imports = True
source_modules =
    app.core
forbidden_modules =
    app.hazards
    app.analytics
ignore_imports =
    app.core.db_registry -> app.hazards.models
    app.core.db_registry -> app.hazards.event_handlers.export_geoparquet
    app.core.jobs.handlers.effis_sync -> app.hazards.repos.hazard_event
    app.core.jobs.handlers.effis_sync -> app.hazards.repos.sync_state
    app.core.jobs.handlers.effis_sync -> app.hazards.use_cases.sync_effis
    app.core.jobs.handlers.ign_sync -> app.hazards.repos.hazard_event
    app.core.jobs.handlers.ign_sync -> app.hazards.repos.sync_state
    app.core.jobs.handlers.ign_sync -> app.hazards.use_cases.sync_ign
    app.core.jobs.handlers.aemet_sync -> app.hazards.repos.hazard_event
    app.core.jobs.handlers.aemet_sync -> app.hazards.repos.sync_state
    app.core.jobs.handlers.aemet_sync -> app.hazards.use_cases.sync_aemet

# ---------------------------------------------------------------------------
# Capas del contexto hazards: una capa solo importa las de abajo.
# api -> use_cases -> repos -> services -> schemas -> models.
# ---------------------------------------------------------------------------
[importlinter:contract:hazards-por-capas]
name = hazards respeta el orden de capas
type = layers
layers =
    app.hazards.api
    app.hazards.use_cases
    app.hazards.repos
    app.hazards.services
    app.hazards.schemas
    app.hazards.models

# ---------------------------------------------------------------------------
# Capas del contexto analytics: api -> use_cases -> queries -> engine.
# paths y schemas son hojas compartidas al fondo.
# ---------------------------------------------------------------------------
[importlinter:contract:analytics-por-capas]
name = analytics respeta el orden de capas
type = layers
layers =
    app.analytics.api
    app.analytics.use_cases
    app.analytics.queries
    app.analytics.engine
    app.analytics.paths
    app.analytics.schemas

# ---------------------------------------------------------------------------
# Frontera de planos (ADR-0012). analytics SOLO lee GeoParquet: prohibido
# tocar Postgres (db/repo), los workers o el dominio hazards. Y los planos
# no se conocen entre si: la unica interfaz es el layout de los parquet.
# ---------------------------------------------------------------------------
[importlinter:contract:analytics-solo-parquet]
name = analytics no toca postgres ni los workers
type = forbidden
source_modules =
    app.analytics
forbidden_modules =
    app.core.db
    app.core.db_registry
    app.core.repo
    app.core.events
    app.core.jobs

[importlinter:contract:planos-independientes]
name = hazards y analytics no se importan entre si
type = independence
modules =
    app.hazards
    app.analytics
